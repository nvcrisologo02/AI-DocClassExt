{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "func: host start",
      "type": "func",
      "dependsOn": [
        "start (azurite)",
        "build (functions)"
      ],
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}/src/backend/DocumentIA.Functions"
      },
      "command": "host start",
      "isBackground": true,
      "problemMatcher": "$func-dotnet-watch"
    },
    {
      "label": "Run Host Functions con todo lo que implique",
      "type": "shell",
      "dependsOn": [
        "start mock servers",
        "func: host start"
      ],
      "dependsOrder": "sequence",
      "command": "Write-Output 'Functions host started with dependencies'",
      "problemMatcher": []
    },
    {
      "label": "start Azurite",
      "type": "process",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\legacy\\start-azurite.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "start (azurite)",
      "type": "shell",
      "dependsOn": "start Azurite",
      "command": "Write-Output 'start Azurite alias'",
      "problemMatcher": []
    },
    {
      "label": "stop (azurite)",
      "type": "process",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\legacy\\stop-azurite.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "clean (functions)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "clean",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src\\backend\\DocumentIA.Functions"
      }
    },
    {
      "label": "build (functions)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "dependsOn": "clean (functions)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src\\backend\\DocumentIA.Functions"
      }
    },
    {
      "label": "clean release (functions)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "clean",
        "--configuration",
        "Release",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src\\backend\\DocumentIA.Functions"
      }
    },
    {
      "label": "publish (functions)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "--configuration",
        "Release",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "dependsOn": "clean release (functions)",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src\\backend\\DocumentIA.Functions"
      }
    },
    {
      "label": "start mock servers",
      "type": "process",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\Mock Servers\\start-mock-servers.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "start (mock servers)",
      "type": "shell",
      "dependsOn": "start mock servers",
      "command": "Write-Output 'start mock servers alias'",
      "problemMatcher": []
    },
    {
      "label": "stop mock server",
      "type": "process",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\Mock Servers\\stop-mock-servers.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "stop (mock servers)",
      "type": "shell",
      "dependsOn": "stop mock server",
      "command": "Write-Output 'stop mock server alias'",
      "problemMatcher": []
    },
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "run"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build (frontend admin)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/frontend/DocumentIA.Admin"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run (build + run) Frontend admin",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--launch-profile",
        "http"
      ],
      "dependsOn": "build (frontend admin)",
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}/src/frontend/DocumentIA.Admin"
      },
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run (frontend web)",
      "type": "shell",
      "dependsOn": "Run (build + run) Frontend admin",
      "command": "Write-Output 'run frontend web alias'",
      "problemMatcher": []
    },
    {
      "label": "build (AssetResolver)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/plugins/DocumentIA.AssetResolver"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run (build + run) AssetResolver",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run"
      ],
      "dependsOn": "build (AssetResolver)",
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}/src/plugins/DocumentIA.AssetResolver"
      },
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "plugins"
      }
    },
    {
      "label": "run (AssetResolver)",
      "type": "shell",
      "dependsOn": "Run (build + run) AssetResolver",
      "command": "Write-Output 'run AssetResolver alias'",
      "problemMatcher": []
    },
    {
      "label": "run (frontend desktop)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/frontend/DocumentIA.Desktop"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}