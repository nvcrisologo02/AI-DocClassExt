{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Azure Functions: Launch (.NET)",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/backend/DocumentIA.Functions/DocumentIA.Functions.csproj",
            "preLaunchTask": "build (functions)",
            "cwd": "${workspaceFolder}/src/backend/DocumentIA.Functions"
        },
        {
            "name": "Azure Functions: Attaching to Host Process",
            "type": "coreclr",
            "request": "attach",
            "preLaunchTask": "func: host start",
            "processId": "${command:azureFunctions.pickProcess}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "symbolSearchPath": "${workspaceFolder}/src/backend/DocumentIA.Functions/bin/Debug/net8.0"
        },
        {
            "name": "Azure Functions: Direct Launch (Alternative)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/backend/DocumentIA.Functions/bin/Debug/net8.0/DocumentIA.Functions.dll",
            "args": [
                "host",
                "start"
            ],
            "cwd": "${workspaceFolder}/src/backend/DocumentIA.Functions",
            "stopAtEntry": false,
            "serverReadyAction": {
                "pattern": "Host started.*",
                "uriFormat": "http://localhost:7071/api",
                "action": "openExternally"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "PowerShell: Launch Current File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "args": []
        },
        {
            "name": "Attach to .NET Functions",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:azureFunctions.pickProcess}"
        },
        {
            "name": "DocumentIA.Batch: Launch (startup break)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder:DocumentIA.Batch}/src/DocumentIA.Batch/bin/Debug/net8.0-windows/DocumentIA.Batch.dll",
            "cwd": "${workspaceFolder:DocumentIA.Batch}/src/DocumentIA.Batch",
            "console": "internalConsole",
            "stopAtEntry": false,
            "justMyCode": true,
            "env": {
                "DOCIA_BATCH_DEBUG_BREAK_ON_STARTUP": "1"
            }
        },
        {
            "name": "DocumentIA.Batch: Launch (normal)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder:DocumentIA.Batch}/src/DocumentIA.Batch/bin/Debug/net8.0-windows/DocumentIA.Batch.dll",
            "cwd": "${workspaceFolder:DocumentIA.Batch}/src/DocumentIA.Batch",
            "console": "internalConsole",
            "stopAtEntry": false,
            "justMyCode": true
        },
        {
            "name": "DocumentIA.Batch: Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
