{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "functions",
            "type": "coreclr",
            "request": "attach",
            "preLaunchTask": "Run Host Functions con todo lo que implique",
            "processId": "${command:azureFunctions.pickProcess}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder:documento-ia-clasificacion-mvp}/src/backend/DocumentIA.Functions",
            "symbolSearchPath": "${workspaceFolder:documento-ia-clasificacion-mvp}/src/backend/DocumentIA.Functions/bin/Debug/net8.0"
        },
        {
            "name": "Batch",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (DocumentIA.Batch)",
            "program": "${workspaceFolder:DocumentIA.Batch}/src/DocumentIA.Batch/bin/Debug/net8.0-windows/DocumentIA.Batch.dll",
            "cwd": "${workspaceFolder:DocumentIA.Batch}/src/DocumentIA.Batch",
            "console": "internalConsole",
            "stopAtEntry": false,
            "justMyCode": true
        },
        {
            "name": "Batch.Classification",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (DocumentIA.Batch.Classification)",
            "program": "${workspaceFolder:DocumentIA.Batch}/src/DocumentIA.Batch.Classification/bin/Debug/net8.0-windows/DocumentIA.Batch.Classification.dll",
            "cwd": "${workspaceFolder:DocumentIA.Batch}/src/DocumentIA.Batch.Classification",
            "console": "internalConsole",
            "stopAtEntry": false,
            "justMyCode": true
        },
        {
            "name": "AssetResolver",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (AssetResolver)",
            "program": "${workspaceFolder:documento-ia-clasificacion-mvp}/src/plugins/DocumentIA.AssetResolver/bin/Debug/net8.0/DocumentIA.AssetResolver.dll",
            "cwd": "${workspaceFolder:documento-ia-clasificacion-mvp}/src/plugins/DocumentIA.AssetResolver",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "justMyCode": true
        },
        {
            "name": "Frontend admin",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (frontend admin)",
            "program": "${workspaceFolder:documento-ia-clasificacion-mvp}/src/frontend/DocumentIA.Admin/bin/Debug/net8.0/DocumentIA.Admin.dll",
            "cwd": "${workspaceFolder:documento-ia-clasificacion-mvp}/src/frontend/DocumentIA.Admin",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "justMyCode": true,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "PowerShell: Launch Current File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "args": []
        }
    ]
}
