<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:DocumentIA.Desktop.Converters">

    <!-- Converters -->
    <local:ActivityStatusToBrushConverter x:Key="StatusToBrushConverter"/>
    <local:ActivityStatusToStringConverter x:Key="StatusToStringConverter"/>
    <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <local:EqualsConverter x:Key="EqualsConverter"/>
    <local:DurationToDisplayConverter x:Key="DurationToDisplayConverter"/>

    <!-- Colors -->
    <Color x:Key="ColorSuccess">#4CAF50</Color>
    <Color x:Key="ColorRunning">#FFC107</Color>
    <Color x:Key="ColorFailed">#F44336</Color>
    <Color x:Key="ColorPending">#BDBDBD</Color>
    <Color x:Key="ColorBackground">#F5F5F5</Color>
    <Color x:Key="ColorBorder">#CCCCCC</Color>

    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="BrushRunning" Color="{StaticResource ColorRunning}"/>
    <SolidColorBrush x:Key="BrushFailed" Color="{StaticResource ColorFailed}"/>
    <SolidColorBrush x:Key="BrushPending" Color="{StaticResource ColorPending}"/>
    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}"/>
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}"/>

    <!-- Pulse Animation (for active activity indicator) -->
    <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)">
            <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="0.4"/>
            <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
            <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1.2"/>
            <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
            <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1.2"/>
            <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1"/>
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Button Styles -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushSuccess}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Border.CornerRadius" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#45A049"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#BDBDBD"/>
                <Setter Property="Foreground" Value="#757575"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Activity Circle Styles -->
    <Style x:Key="ActivityCircle" TargetType="Ellipse">
        <Setter Property="Width" Value="50"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="Margin" Value="10"/>
    </Style>

</ResourceDictionary>
