<UserControl x:Class="DocumentIA.Desktop.Views.ActivityTimelineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DocumentIA.Desktop"
             xmlns:models="clr-namespace:DocumentIA.Desktop.Models"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="400">
    <Grid Background="White" Margin="10">
        <StackPanel Orientation="Vertical" VerticalAlignment="Top">
            <TextBlock Text="Estado de Actividades" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <ItemsControl ItemsSource="{Binding ActivityStatuses}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="5">
                            <Ellipse x:Name="ActivityCircle" Width="50" Height="50" 
                                     Fill="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                     Margin="5" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ActivityStatusEnum.Running}">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Storyboard="{StaticResource PulseAnimation}"/>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            
                            <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" FontSize="11" TextWrapping="Wrap" Width="60"/>
                            <TextBlock Text="{Binding DurationMs, Converter={StaticResource DurationToDisplayConverter}}"
                                       HorizontalAlignment="Center" FontSize="9" Foreground="#666"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
