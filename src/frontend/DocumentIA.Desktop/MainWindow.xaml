<Window x:Class="DocumentIA.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DocumentIA.Desktop"
        xmlns:views="clr-namespace:DocumentIA.Desktop.Views"
        mc:Ignorable="d"
        Title="DocumentIA - Test Runner" Height="900" Width="1200" WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <DockPanel>
        <!-- Status Bar -->
        <Border DockPanel.Dock="Top" Background="White" Padding="10" Height="50">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="20" Height="20" Margin="0,0,10,0" Fill="Green"/>
                <TextBlock Text="{Binding ApiStatusMessage}" Margin="0,0,20,0" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Text="{Binding InstanceId}" Margin="0,0,20,0" VerticalAlignment="Center" FontSize="11" Foreground="#666"/>
                <TextBlock Text="{Binding CorrelationId}" VerticalAlignment="Center" FontSize="11" Foreground="#666"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <DockPanel DockPanel.Dock="Top" Margin="10">
            <!-- Left Panel: Activity Timeline -->
            <StackPanel DockPanel.Dock="Left" Width="550" Margin="0,0,10,0">
                <views:ActivityTimelineControl DataContext="{Binding}" Height="200"/>
            </StackPanel>

            <!-- Right Panel: Activity Log -->
            <StackPanel DockPanel.Dock="Right" Margin="10,0,0,0">
                <TextBlock Text="Registro de Actividades" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListBox ItemsSource="{Binding ActivityLogs}" Height="180" Background="White" Foreground="Black">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Courier New" FontSize="10" Margin="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </DockPanel>

        <!-- File Selection & Execution -->
        <Border DockPanel.Dock="Top" Background="White" Padding="10" Margin="10,0,10,10">
            <Grid Height="120">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: File Selection -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Documento PDF:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,5"/>
            
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding SelectedDocumentPath}" 
                      Background="#F0F0F0" Padding="10" Foreground="#333" Margin="0,0,10,0" Height="35" VerticalAlignment="Center"/>
            
            <Button Grid.Row="1" Grid.Column="1" Content="Seleccionar..." Command="{Binding SelectFileCommand}" 
                   Style="{StaticResource ButtonPrimary}" Width="100" Margin="0,0,10,0"/>

            <!-- Row 2: Classification Type -->
            <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="Tipo de Documento:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,5"/>

            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton Content="Nota Simple 1.4" GroupName="DocType" Margin="0,0,20,0" VerticalAlignment="Center"
                            IsChecked="{Binding SelectedClassificationType, Converter={StaticResource EqualsConverter}, ConverterParameter=nota-simple@1.4}"/>
                <RadioButton Content="Resumen Documental" GroupName="DocType" Margin="0,0,20,0" VerticalAlignment="Center"
                            IsChecked="{Binding SelectedClassificationType, Converter={StaticResource EqualsConverter}, ConverterParameter=resumen-documental}"/>
                <RadioButton Content="Auto-clasificar" GroupName="DocType" VerticalAlignment="Center"
                            IsChecked="{Binding SelectedClassificationType, Converter={StaticResource EqualsConverter}, ConverterParameter=auto}"/>
            </StackPanel>

            <!-- Execute Button -->
            <Button Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Content="EJECUTAR" Command="{Binding ExecuteCommand}"
                   Style="{StaticResource ButtonPrimary}" Height="40" FontSize="16" 
                   IsEnabled="{Binding IsExecuteEnabled}"/>
            </Grid>
        </Border>

        <!-- JSON Viewer -->
        <views:JsonViewerControl x:Name="JsonViewer" DockPanel.Dock="Bottom" Margin="10" Height="300"/>
    </DockPanel>
</Window>
