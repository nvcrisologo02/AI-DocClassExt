<Window x:Class="DocumentIA.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DocumentIA.Desktop"
        xmlns:views="clr-namespace:DocumentIA.Desktop.Views"
        mc:Ignorable="d"
        Title="DocumentIA - Test Runner" Height="860" Width="1320" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushAppBackground}" WindowState="Normal" Topmost="False"
        FontFamily="Segoe UI Variable Display,Segoe UI">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.05*" MinWidth="360"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Input -->
        <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PANEL DE ENTRADA" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>

                <Border Grid.Row="1" Margin="0,14,0,0" Padding="10" BorderBrush="#3A4458" BorderThickness="1" CornerRadius="6" Background="#131A26">
                    <StackPanel>
                        <TextBlock Text="DOCUMENTO" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedDocumentPath}" Foreground="{StaticResource BrushTextPrimary}" FontSize="12" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <TextBlock Text="TIPOLOGÍA" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Vertical">
                        <RadioButton Content="Nota Simple 1.4" GroupName="DocType" Margin="0,0,0,4" Foreground="{StaticResource BrushTextPrimary}"
                                     IsChecked="{Binding SelectedClassificationType, Converter={StaticResource EqualsConverter}, ConverterParameter=nota-simple@1.4}"/>
                        <RadioButton Content="Resumen" GroupName="DocType" Margin="0,0,0,4" Foreground="{StaticResource BrushTextPrimary}"
                                     IsChecked="{Binding SelectedClassificationType, Converter={StaticResource EqualsConverter}, ConverterParameter=resumen-documental}"/>
                        <RadioButton Content="Auto" GroupName="DocType" Foreground="{StaticResource BrushTextPrimary}"
                                     IsChecked="{Binding SelectedClassificationType, Converter={StaticResource EqualsConverter}, ConverterParameter=auto}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Row="3" Content="SELECCIONAR DOCUMENTO" Command="{Binding SelectFileCommand}" Style="{StaticResource ButtonSecondary}" Margin="0,14,0,0" Height="34"/>

                <StackPanel Grid.Row="4" Margin="0,14,0,0">
                    <TextBlock Text="OPCIONES" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,8"/>
                    <CheckBox Content="skipDuplicateCheck" IsChecked="{Binding SkipDuplicateCheck}" Margin="0,0,0,8" Foreground="{StaticResource BrushTextPrimary}"/>
                    <CheckBox Content="forceReprocess" IsChecked="{Binding ForceReprocess}" Margin="0,0,0,8" Foreground="{StaticResource BrushTextPrimary}"/>
                    <CheckBox Content="skipGDCUpload" IsChecked="{Binding SkipGDCUpload}" Foreground="{StaticResource BrushTextPrimary}"/>

                    <TextBlock Text="PARÁMETROS REQUEST" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,14,0,8"/>

                    <TextBlock Text="idActivo" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding InputIdActivo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                    <TextBlock Text="submittedBy" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding InputSubmittedBy, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                    <TextBlock Text="classification.provider" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ClassificationProvider, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                    <TextBlock Text="classification.model" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ClassificationModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                    <TextBlock Text="classification.umbral" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ClassificationThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                    <TextBlock Text="extraction.model" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ExtractionModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                    <TextBlock Text="extraction.umbral" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ExtractionThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                    <TextBlock Text="API check (segundos)" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ApiCheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>
                </StackPanel>

                <Button Grid.Row="5" Content="EJECUTAR" Command="{Binding ExecuteCommand}" Style="{StaticResource ButtonPrimary}" Height="38" Margin="0,12,0,0" IsEnabled="{Binding IsExecuteEnabled}"/>
            </Grid>
        </Border>

        <!-- Center: Monitoring -->
        <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="MONITOREO" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>

                <Grid Grid.Row="1" Margin="0,12,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="12" Height="12" Margin="0,0,8,0" Fill="{Binding IsApiConnected, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="ESTADO API" Foreground="{StaticResource BrushTextPrimary}" FontSize="11"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding ApiStatusMessage}" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="14,0,0,0" VerticalAlignment="Center"/>

                    <Button Grid.Column="2" Content="Copiar" Style="{StaticResource ButtonSecondary}" Height="26" MinWidth="58"/>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding InstanceId, StringFormat=INSTANCE ID: {0}}"
                               Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,10"/>

                    <Border Grid.Row="1" Grid.Column="0" Background="#111722" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Padding="10" Height="420" VerticalAlignment="Top" Margin="0,0,10,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <views:ActivityTimelineControl DataContext="{Binding}"/>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Background="#131A26" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="LOG DE ACTIVIDAD" Foreground="{StaticResource BrushTextPrimary}" FontSize="11" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding ActivityLogs}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource BrushTextMuted}" FontFamily="Consolas" FontSize="10"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Right: Results -->
        <Border Grid.Column="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="RESULTADOS" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>

                <Border Grid.Row="1" Margin="0,12,0,0" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Background="#0E131E">
                    <views:JsonViewerControl x:Name="JsonViewer"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
