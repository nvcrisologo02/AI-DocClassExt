<Window x:Class="DocumentIA.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DocumentIA.Desktop"
        xmlns:views="clr-namespace:DocumentIA.Desktop.Views"
        mc:Ignorable="d"
        Title="DocumentIA - Test Runner" Height="860" Width="1320" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushAppBackground}" WindowState="Normal" Topmost="False"
        FontFamily="Segoe UI Variable Display,Segoe UI">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.05*" MinWidth="360"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Input -->
        <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PANEL DE ENTRADA" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,14,0,0">
                    <StackPanel>

                        <!-- ENTORNO -->
                        <Border Padding="10" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#3A4458"/>
                                    <Setter Property="Background" Value="#131A26"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseAzure}" Value="True">
                                            <Setter Property="BorderBrush" Value="#0078D4"/>
                                            <Setter Property="Background" Value="#0D1E33"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="ENTORNO" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CurrentEnvironmentLabel}"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#8899AA"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UseAzure}" Value="True">
                                                        <Setter Property="Foreground" Value="#3AA0F3"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding UseAzure, Mode=TwoWay}"
                                                  Width="44" Height="22" VerticalAlignment="Center"
                                                  BorderThickness="0" Cursor="Hand">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="track" CornerRadius="11" Width="44" Height="22"
                                                                    Background="#3A4458" Padding="2">
                                                                <Border x:Name="thumb" Width="18" Height="18"
                                                                        CornerRadius="9" Background="#8899AA"
                                                                        HorizontalAlignment="Left"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="track" Property="Background" Value="#0078D4"/>
                                                                    <Setter TargetName="thumb" Property="Background" Value="White"/>
                                                                    <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="track" Property="Opacity" Value="0.85"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                </Grid>
                                <TextBlock Text="{Binding CurrentEnvironmentUrl}" Foreground="#556070"
                                           FontSize="9" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                <!-- Function Key (solo visible en Azure) -->
                                <StackPanel Visibility="{Binding ShowFunctionKeyField, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,8,0,0">
                                    <TextBlock Text="Function Key" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding AzureFunctionKey, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6" Background="#0A1520" Foreground="{StaticResource BrushTextPrimary}"
                                             BorderBrush="#0078D4" FontFamily="Consolas" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="10" BorderBrush="#3A4458" BorderThickness="1" CornerRadius="6" Background="#131A26">
                            <StackPanel>
                                <TextBlock Text="DOCUMENTO" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedDocumentPath}" Foreground="{StaticResource BrushTextPrimary}" FontSize="12" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <Button Content="SELECCIONAR DOCUMENTO" Command="{Binding SelectFileCommand}" Style="{StaticResource ButtonSecondary}" Margin="0,8,0,0" Height="34"/>

                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Text="TIPOLOGÍA" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding AvailableTipologias}"
                                      SelectedItem="{Binding SelectedTipologia, Mode=TwoWay}"
                                      DisplayMemberPath="Display"
                                      Height="30"/>
                        </StackPanel>

                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Text="OPCIONES" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,8"/>
                            <CheckBox Content="skipDuplicateCheck" IsChecked="{Binding SkipDuplicateCheck}" Margin="0,0,0,8" Foreground="{StaticResource BrushTextPrimary}"/>
                            <CheckBox Content="forceReprocess" IsChecked="{Binding ForceReprocess}" Margin="0,0,0,8" Foreground="{StaticResource BrushTextPrimary}"/>
                            <CheckBox Content="skipGDCUpload" IsChecked="{Binding SkipGDCUpload}" Foreground="{StaticResource BrushTextPrimary}"/>

                            <TextBlock Text="PARÁMETROS REQUEST" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,14,0,8"/>

                            <TextBlock Text="idActivo" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding InputIdActivo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="submittedBy" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding InputSubmittedBy, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="documento.objectIdGDC" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Text="Si se informa, se enviará por ObjectIdGDC (sin Base64). El fichero local pasa a ser opcional." Foreground="#556070" FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBox Text="{Binding InputObjectIdGdc, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="classification.provider" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ClassificationProvider, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="classification.model" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ClassificationModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="classification.umbral" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Text="Confianza mínima de clasificación para aceptar el tipo detectado (0–1)." Foreground="#556070" FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBox Text="{Binding ClassificationThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="extraction.model" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ExtractionModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="extraction.umbral" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Text="Umbral legado: aplica a completitud y confianza si no se informan los específicos (0–1)." Foreground="#556070" FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBox Text="{Binding ExtractionThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="extraction.umbralCompletitud" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Text="Ratio mín. de campos esperados presentes en la extracción CU (0–1). Vacío = usa tipología o global." Foreground="#556070" FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBox Text="{Binding ExtractionThresholdCompletitud, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="extraction.umbralConfianza" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Text="Confianza CU mínima para no activar el fallback a GPT (0–1). Vacío = usa tipología o global." Foreground="#556070" FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBox Text="{Binding ExtractionThresholdConfianza, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="ASSETRESOLVER (OVERRIDES)" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,10,0,8"/>

                            <TextBlock Text="assetResolver.enabled" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Text="auto = usa configuración de tipología; true/false = fuerza ejecución u omisión." Foreground="#556070" FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <ComboBox ItemsSource="{Binding AssetResolverEnabledOptions}"
                                      SelectedItem="{Binding AssetResolverEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,8" Height="30"/>

                            <TextBlock Text="assetResolver.camposBusqueda.idufir" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AssetResolverIdufir, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="assetResolver.camposBusqueda.referenciaCatastral" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AssetResolverReferenciaCatastral, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>

                            <TextBlock Text="assetResolver.camposSolicitados" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Text="Lista separada por coma, punto y coma o salto de línea. Usar nombres de columna de BBDD o #ALL# para devolver todas." Foreground="#556070" FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBox Text="{Binding AssetResolverCamposSolicitados, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="54"/>

                            <TextBlock Text="API check (segundos)" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ApiCheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Padding="6" Background="#131A26" Foreground="{StaticResource BrushTextPrimary}" BorderBrush="#3A4458"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="EJECUTAR" Command="{Binding ExecuteCommand}" Style="{StaticResource ButtonPrimary}" Height="38" IsEnabled="{Binding IsExecuteEnabled}" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="CANCELAR" Command="{Binding CancelCommand}" Height="38" MinWidth="90" IsEnabled="{Binding IsCancelEnabled}"
                            Background="#8B1A1A" Foreground="White" FontWeight="SemiBold" FontSize="12"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#8B1A1A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#3A2020"/>
                                        <Setter Property="Foreground" Value="#666"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C0392B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Center: Monitoring -->
        <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="MONITOREO" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>

                <Grid Grid.Row="1" Margin="0,12,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="12" Height="12" Margin="0,0,8,0" Fill="{Binding IsApiConnected, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="ESTADO API" Foreground="{StaticResource BrushTextPrimary}" FontSize="11"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding ApiStatusMessage}" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="14,0,0,0" VerticalAlignment="Center"/>

                    <Button Grid.Column="2" Content="Copiar" Style="{StaticResource ButtonSecondary}" Height="26" MinWidth="58"/>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding InstanceId, StringFormat=INSTANCE ID: {0}}"
                               Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,10"/>

                    <Border Grid.Row="1" Grid.Column="0" Background="#111722" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Padding="10" Height="420" VerticalAlignment="Top" Margin="0,0,10,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <views:ActivityTimelineControl DataContext="{Binding}"/>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Background="#131A26" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="LOG DE ACTIVIDAD" Foreground="{StaticResource BrushTextPrimary}" FontSize="11" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding ActivityLogs}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource BrushTextMuted}" FontFamily="Consolas" FontSize="10"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Right: Results -->
        <Border Grid.Column="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="RESULTADOS" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>

                <Border Grid.Row="1" Margin="0,12,0,0" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Background="#0E131E">
                    <views:JsonViewerControl x:Name="JsonViewer"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
