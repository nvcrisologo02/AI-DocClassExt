@implements IAsyncDisposable
@rendermode InteractiveServer
@inject IJSRuntime JS

<div class="json-editor-wrapper">
    <div class="json-editor-toolbar mb-2">
        @if (!ReadOnly && SupportedModes != null && SupportedModes.Any())
        {
            <div class="mode-selector btn-group" role="group">
                <label class="form-label me-2">Modo:</label>
                @foreach (var mode in SupportedModes)
                {
                    <input type="radio" class="btn-check" name="@EditorId" id="@($"{EditorId}-mode-{mode}")" 
                           autocomplete="off" @onchange="@((ChangeEventArgs e) => OnModeChanged(mode))" />
                    <label class="btn btn-outline-secondary" for="@($"{EditorId}-mode-{mode}")">
                        @mode
                    </label>
                }
            </div>
        }
    </div>
    
    <div id="@EditorId" class="json-editor-container" style="height: @Height; width: 100%;"></div>
    
    @if (!ReadOnly && ShowValidationMessage && !JsonIsValid)
    {
        <div class="alert alert-danger mt-2" role="alert">
            <small>JSON inválido: @ValidationError</small>
        </div>
    }
</div>

@code {
    private string EditorId { get; } = $"json-editor-{Guid.NewGuid()}";
    private bool JsonIsValid = true;
    private string? ValidationError;

    /// <summary>
    /// JSON content to display in the editor
    /// </summary>
    [Parameter]
    public string? JsonContent { get; set; }

    /// <summary>
    /// Event callback when JSON content changes
    /// </summary>
    [Parameter]
    public EventCallback<string> OnJsonChange { get; set; }

    /// <summary>
    /// Initial mode for the editor (tree, form, code, text, preview)
    /// </summary>
    [Parameter]
    public string Mode { get; set; } = "tree";

    /// <summary>
    /// List of available modes (e.g., tree, form, code, text, preview)
    /// </summary>
    [Parameter]
    public List<string> SupportedModes { get; set; } = new() { "tree", "form", "code" };

    /// <summary>
    /// Whether the editor is read-only
    /// </summary>
    [Parameter]
    public bool ReadOnly { get; set; } = false;

    /// <summary>
    /// Height of the editor container
    /// </summary>
    [Parameter]
    public string Height { get; set; } = "400px";

    /// <summary>
    /// Show validation error message
    /// </summary>
    [Parameter]
    public bool ShowValidationMessage { get; set; } = true;

    private string? _previousJsonContent;
    private bool _editorInitialized = false;

    protected override async Task OnParametersSetAsync()
    {
        // Si el JSON cambió y el editor ya está inicializado, actualizar el editor
        if (_editorInitialized && _previousJsonContent != JsonContent && !string.IsNullOrWhiteSpace(JsonContent))
        {
            await SetJsonAsync(JsonContent);
        }
        _previousJsonContent = JsonContent;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Acceder a window.jsonEditorInterop directamente (está definido como global en json-editor-interop.js)
                await JS.InvokeVoidAsync("jsonEditorInterop.initEditor", EditorId, Mode, ReadOnly);
                _editorInitialized = true;
                
                // Set initial JSON content if provided
                if (!string.IsNullOrWhiteSpace(JsonContent))
                {
                    await SetJsonAsync(JsonContent);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing JSONEditor: {ex.Message}");
            }
        }
    }

    /// <summary>
    /// Set JSON content programmatically
    /// </summary>
    public async Task SetJsonAsync(string jsonString)
    {
        try
        {
            await JS.InvokeVoidAsync("jsonEditorInterop.setJson", EditorId, jsonString);
            JsonContent = jsonString;
            ValidateJson();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error setting JSON: {ex.Message}");
        }
    }

    /// <summary>
    /// Get JSON content from the editor
    /// </summary>
    public async Task<string?> GetJsonAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("jsonEditorInterop.getJson", EditorId);
            if (json != null)
            {
                JsonContent = json;
                ValidateJson();
            }
            return json;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error getting JSON: {ex.Message}");
            return null;
        }
    }

    /// <summary>
    /// Get text content (non-JSON) from the editor
    /// </summary>
    public async Task<string?> GetTextAsync()
    {
        try
        {
            return await JS.InvokeAsync<string?>("jsonEditorInterop.getText", EditorId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error getting text: {ex.Message}");
            return null;
        }
    }

    /// <summary>
    /// Change the editor mode
    /// </summary>
    public async Task SetModeAsync(string newMode)
    {
        try
        {
            await JS.InvokeVoidAsync("jsonEditorInterop.setMode", EditorId, newMode);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error setting mode: {ex.Message}");
        }
    }

    /// <summary>
    /// Get current editor mode
    /// </summary>
    public async Task<string?> GetModeAsync()
    {
        try
        {
            return await JS.InvokeAsync<string?>("jsonEditorInterop.getMode", EditorId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error getting mode: {ex.Message}");
            return null;
        }
    }

    /// <summary>
    /// Validate JSON content
    /// </summary>
    public async Task<bool> ValidateAsync()
    {
        try
        {
            // Usar una clase específica para recibir el resultado en lugar de dynamic
            var result = await JS.InvokeAsync<JsonValidationResult>("jsonEditorInterop.validateJson", EditorId);
            if (result != null)
            {
                JsonIsValid = result.Valid;
                ValidationError = JsonIsValid ? null : result.Error;
            }
            return JsonIsValid;
        }
        catch (Exception ex)
        {
            JsonIsValid = false;
            ValidationError = ex.Message;
            return false;
        }
    }

    private void ValidateJson()
    {
        if (string.IsNullOrWhiteSpace(JsonContent))
        {
            JsonIsValid = false;
            ValidationError = "JSON no puede estar vacío";
            return;
        }

        try
        {
            System.Text.Json.JsonDocument.Parse(JsonContent);
            JsonIsValid = true;
            ValidationError = null;
        }
        catch (Exception ex)
        {
            JsonIsValid = false;
            ValidationError = ex.Message;
        }
    }

    /// <summary>
    /// Clase para representar el resultado de validación JSON desde JavaScript
    /// </summary>
    private class JsonValidationResult
    {
        public bool Valid { get; set; }
        public string? Error { get; set; }
    }

    private async Task OnModeChanged(string newMode)
    {
        await SetModeAsync(newMode);
        Mode = newMode;
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("jsonEditorInterop.destroyEditor", EditorId);
        }
        catch (JSDisconnectedException)
        {
            // Ignored
        }
    }
}

<style>
.json-editor-wrapper {
    border: 1px solid #dee2e6;
    border-radius: 0.375rem;
    padding: 1rem;
    background-color: #fff;
}

.json-editor-toolbar {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.mode-selector {
    display: flex;
    gap: 0.5rem;
}

.json-editor-container {
    border: 1px solid #dee2e6;
    border-radius: 0.375rem;
    overflow: hidden;
}

.json-editor-container :deep(.jsoneditor) {
    border: none;
    border-radius: 0.375rem;
}

.json-editor-container :deep(.jsoneditor-menu) {
    background-color: #f8f9fa;
    border-bottom: 1px solid #dee2e6;
}

.json-editor-container :deep(.jsoneditor-tree .jsoneditor-value) {
    padding-left: 4px;
}
</style>
