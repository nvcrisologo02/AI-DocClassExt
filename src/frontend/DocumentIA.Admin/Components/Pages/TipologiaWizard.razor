    private bool TryGetRule(int fieldIndex, int ruleIndex, out TipologiaWizardRuleDraft rule)
    {
        rule = null!;
        if (fieldIndex < 0 || fieldIndex >= WizardState.Draft.Fields.Count)
        {
            return false;
        }

        var rules = WizardState.Draft.Fields[fieldIndex].Rules;
        if (ruleIndex < 0 || ruleIndex >= rules.Count)
        {
            return false;
        }

        rule = rules[ruleIndex];
        return true;
    }

