    private async Task LoadCloneSourceAsync()
    {
        _message = null;
        if (_tipologias.Count == 0)
        {
            _error = true;
            _message = "No hay tipologías cargadas para clonar (la API COMPLETAR_GDC_HTTP_BASIC_USERNAME no respondió correctamente).";
            return;
        }

        if (!_cloneSourceId.HasValue)
        {
            _error = true;
            _message = "Selecciona una tipología origen para clonar.";
            return;
        }

        var ok = await WizardState.TryCloneFromTipologiaAsync(_cloneSourceId.Value, AdminService);
        if (!ok)
        {
            _error = true;
            _message = "No se encontró la tipología seleccionada.";
            return;
        }

        await WizardState.SaveDraftAsync(JS);
        _error = false;
        _message = "Datos base de clonación cargados.";
    }

