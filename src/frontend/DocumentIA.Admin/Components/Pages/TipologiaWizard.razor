    private async Task<bool> ValidateStepAsync(int step)
    {
        var errors = step switch
        {
            1 => await ValidateStep1Async(),
            2 => ValidateStep2(),
            3 => ValidateStep3(),
            4 => ValidateStep4(),
            _ => await ValidateFinalAsync()
        };

        _stepErrors[step] = errors;
        _error = errors.Count > 0;
        _message = errors.Count > 0 ? "Revisa los errores antes de continuar." : null;

        return errors.Count == 0;
    }

    private async Task<List<string>> ValidateStep1Async()
    {
        var errors = new List<string>();
        var d = WizardState.Draft;

        if (string.IsNullOrWhiteSpace(d.Codigo))
        {
            errors.Add("El código es obligatorio.");
        }
        else if (!System.Text.RegularExpressions.Regex.IsMatch(d.Codigo, "^[a-z0-9][a-z0-9_.-]{2,99}$"))
        {
            errors.Add("El código debe tener entre 3 y 100 caracteres y usar solo minúsculas, números, punto, guion y guion bajo.");
        }

        if (string.IsNullOrWhiteSpace(d.Nombre))
        {
            errors.Add("El nombre es obligatorio.");
        }

        if (string.IsNullOrWhiteSpace(d.Version)
            || !System.Text.RegularExpressions.Regex.IsMatch(d.Version, "^\\d+\\.\\d+(\\.\\d+)?(-[0-9A-Za-z-.]+)?(\\+[0-9A-Za-z-.]+)?$"))
        {
            errors.Add("La versión debe usar formato 1.0 o 1.0.0.");
        }

        if (d.StartMode == TipologiaWizardStartMode.Clonar && !_cloneSourceId.HasValue)
        {
            errors.Add("En modo clonar debes seleccionar una tipología origen.");
        }

        if (d.StartMode == TipologiaWizardStartMode.Plantilla && string.IsNullOrWhiteSpace(d.TemplateCode))
        {
            errors.Add("En modo plantilla debes seleccionar una plantilla.");
        }

        await Task.CompletedTask;
        return errors;
    }

    private List<string> ValidateStep2()
    {
        var errors = new List<string>();
        var d = WizardState.Draft;

        if (string.IsNullOrWhiteSpace(d.ModeloClasificacionDI))
        {
            errors.Add("Debes seleccionar un modelo de clasificación.");
        }

        if (d.UmbralClasificacion is < 0 or > 1)
        {
            errors.Add("El umbral de clasificación debe estar entre 0 y 1.");
        }

        if (string.IsNullOrWhiteSpace(d.Tdn1))
        {
            errors.Add("TDN1 es obligatorio.");
        }

        if (string.IsNullOrWhiteSpace(d.Tdn2))
        {
            errors.Add("TDN2 es obligatorio.");
        }

        if (string.IsNullOrWhiteSpace(d.GptDescripcion))
        {
            errors.Add("La descripción GPT de tipología es obligatoria.");
        }

        if (d.EnableExtraction)
        {
            if (string.IsNullOrWhiteSpace(d.ModeloExtraccionDI))
            {
                errors.Add("Debes seleccionar un modelo de extracción cuando extraction está habilitado.");
            }

            if (d.UmbralExtraccion is < 0 or > 1)
            {
                errors.Add("El umbral de extracción debe estar entre 0 y 1.");
            }
        }

        if (d.EnablePrompting)
        {
            if (string.IsNullOrWhiteSpace(d.PromptModelKey))
            {
                errors.Add("Debes seleccionar un modelo de prompting cuando prompting está habilitado.");
            }

            if (string.IsNullOrWhiteSpace(d.PromptGPT))
            {
                errors.Add("Debes indicar el prompt cuando prompting está habilitado.");
            }
        }

        return errors;
    }

    private List<string> ValidateStep3()
    {
        var errors = new List<string>();
        var d = WizardState.Draft;

        var validFields = d.Fields.Where(f => !string.IsNullOrWhiteSpace(f.Name)).ToArray();
        if (validFields.Length == 0)
        {
            errors.Add("Debes definir al menos un campo.");
        }

        var duplicates = validFields
            .GroupBy(f => f.Name.Trim(), StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() > 1)
            .Select(g => g.Key)
            .ToArray();

        foreach (var duplicate in duplicates)
        {
            errors.Add($"Hay campos duplicados: {duplicate}.");
        }

        foreach (var field in d.Fields)
        {
            if (string.IsNullOrWhiteSpace(field.Name))
            {
                errors.Add("Todos los campos deben tener nombre.");
                continue;
            }

            if (string.IsNullOrWhiteSpace(field.Type))
            {
                errors.Add($"El campo {field.Name} debe tener tipo.");
            }

            foreach (var rule in field.Rules)
            {
                if (string.IsNullOrWhiteSpace(rule.RuleType))
                {
                    errors.Add($"El campo {field.Name} contiene una regla sin tipo.");
                }
            }
        }

        return errors;
    }

    private List<string> ValidateStep4()
    {
        var errors = new List<string>();
        var d = WizardState.Draft;

        if (!d.SkipGdcUpload)
        {
            if (string.IsNullOrWhiteSpace(d.GdcTipoDocumento))
            {
                errors.Add("GdcTipoDocumento es obligatorio cuando no se omite GDC.");
            }

            if (string.IsNullOrWhiteSpace(d.GdcSerie))
            {
                errors.Add("GdcSerie es obligatorio cuando no se omite GDC.");
            }
        }

        return errors;
    }

    private async Task<List<string>> ValidateFinalAsync()
    {
        var errors = new List<string>();
        errors.AddRange(await ValidateStep1Async());
        errors.AddRange(ValidateStep2());
        errors.AddRange(ValidateStep3());
        errors.AddRange(ValidateStep4());

        var entity = new TipologiaEntity
        {
            Codigo = WizardState.Draft.Codigo,
            Nombre = WizardState.Draft.Nombre,
            Version = WizardState.Draft.Version,
            ModeloClasificacionDI = WizardState.Draft.ModeloClasificacionDI,
            UmbralClasificacion = WizardState.Draft.UmbralClasificacion,
            ModeloExtraccionDI = WizardState.Draft.EnableExtraction ? WizardState.Draft.ModeloExtraccionDI : string.Empty,
            UmbralExtraccion = WizardState.Draft.UmbralExtraccion,
            PromptGPT = WizardState.Draft.EnablePrompting ? WizardState.Draft.PromptGPT : string.Empty,
            ConfiguracionJson = WizardState.BuildConfigurationJson()
        };

        errors.AddRange(await AdminService.ValidateTipologiaAsync(entity));

        return errors.Distinct().ToList();
    }

    private async Task SaveAsync()
    {
        await PersistAsync(publishAfterCreate: false);
    }

    private async Task PublishAsync()
    {
        await PersistAsync(publishAfterCreate: true);
    }

    private async Task PersistAsync(bool publishAfterCreate)
    {
        if (!await ValidateFinalAsync().ContinueWith(t =>
            {
                _stepErrors[WizardState.CurrentStep] = t.Result;
                return t.Result.Count == 0;
            }))
        {
            _error = true;
            _message = "No se puede crear la tipología: hay validaciones pendientes.";
            return;
        }

        _saving = true;
        _message = null;

        try
        {
            var draft = WizardState.Draft;
            var entity = new TipologiaEntity
            {
                Codigo = draft.Codigo,
                Nombre = draft.Nombre,
                Version = draft.Version,
                ModeloClasificacionDI = draft.ModeloClasificacionDI,
                UmbralClasificacion = draft.UmbralClasificacion,
                ModeloExtraccionDI = draft.EnableExtraction ? draft.ModeloExtraccionDI : string.Empty,
                UmbralExtraccion = draft.UmbralExtraccion,
                PromptGPT = draft.EnablePrompting ? draft.PromptGPT : string.Empty,
                ConfiguracionJson = WizardState.BuildConfigurationJson(),
                Estado = EstadoTipologia.Draft
            };

            var created = await AdminService.SaveTipologiaAsync(entity);

            if (publishAfterCreate)
            {
                await AdminService.PublishTipologiaAsync(created.Id, "COMPLETAR_GDC_HTTP_BASIC_USERNAME-ui");
            }

            await WizardState.ClearDraftAsync(JS);

            _error = false;
            _message = publishAfterCreate
                ? $"Tipología creada y publicada: {created.Codigo}."
                : $"Tipología creada en Draft: {created.Codigo}.";

            Navigation.NavigateTo(publishAfterCreate ? "/tipologias" : $"/tipologias/edit/{created.Id}");
        }
        catch (Exception ex)
        {
            _error = true;
            _message = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
