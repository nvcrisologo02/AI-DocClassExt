@page "/tipologias/wizard"
@inject TipologiaAdminService AdminService
@inject TipologiaWizardStateService WizardState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Wizard de Tipologías</PageTitle>

<h1>Wizard de alta de tipologías</h1>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_error ? "alert-danger" : "alert-success")">@_message</div>
}

<div class="mb-3 d-flex flex-wrap gap-2">
    @for (var i = 1; i <= WizardState.TotalSteps; i++)
    {
        var css = WizardState.CurrentStep == i ? "btn btn-primary" : "btn btn-outline-secondary";
        <button class="@css" @onclick="() => GoToStepAsync(i)">Paso @i</button>
    }
</div>

<div class="card mb-3">
    <div class="card-header">@GetStepTitle(WizardState.CurrentStep)</div>
    <div class="card-body">
        @if (WizardState.CurrentStep == 1)
        {
            <div class="mb-3">
                <label class="form-label">Código</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.Codigo" @bind-Value:after="MarkDirtyAsync" />
                <small class="text-muted">Solo minúsculas, números, punto, guion y guion bajo.</small>
            </div>

            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.Nombre" @bind-Value:after="MarkDirtyAsync" />
            </div>

            <div class="mb-3">
                <label class="form-label">Versión (SemVer)</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.Version" @bind-Value:after="MarkDirtyAsync" />
            </div>

            <div class="mb-3">
                <label class="form-label">Modo de inicio</label>
                <InputRadioGroup @bind-Value="WizardState.Draft.StartMode" @bind-Value:after="MarkDirtyAsync">
                    <div class="form-check">
                        <InputRadio class="form-check-input" Value="TipologiaWizardStartMode.DesdeCero" />
                        <label class="form-check-label">Desde cero</label>
                    </div>
                    <div class="form-check">
                        <InputRadio class="form-check-input" Value="TipologiaWizardStartMode.Clonar" />
                        <label class="form-check-label">Clonar tipología existente</label>
                    </div>
                    <div class="form-check">
                        <InputRadio class="form-check-input" Value="TipologiaWizardStartMode.Plantilla" />
                        <label class="form-check-label">Usar plantilla</label>
                    </div>
                </InputRadioGroup>
            </div>

            @if (WizardState.Draft.StartMode == TipologiaWizardStartMode.Clonar)
            {
                <div class="mb-3">
                    <label class="form-label">Tipología origen</label>
                    <InputSelect class="form-select" @bind-Value="_cloneSourceId">
                        <option value="">Selecciona una tipología...</option>
                        @foreach (var tipologia in _tipologias)
                        {
                            <option value="@tipologia.Id">@tipologia.Codigo - @tipologia.Nombre (@tipologia.Version)</option>
                        }
                    </InputSelect>
                    <button class="btn btn-outline-primary mt-2" @onclick="LoadCloneSourceAsync" type="button">Cargar datos para clonar</button>
                </div>
            }

            @if (WizardState.Draft.StartMode == TipologiaWizardStartMode.Plantilla)
            {
                <div class="mb-3">
                    <label class="form-label">Plantilla</label>
                    <InputSelect class="form-select" @bind-Value="WizardState.Draft.TemplateCode" @bind-Value:after="ApplyTemplateAsync">
                        <option value="">Selecciona una plantilla...</option>
                        <option value="notasimple">Nota simple</option>
                        <option value="tasacion">Tasación</option>
                        <option value="generica">Genérica</option>
                    </InputSelect>
                </div>
            }
        }
        else if (WizardState.CurrentStep == 2)
        {
            @if (_versionSuggestion is not null && _versionSuggestion.HasChanges)
            {
                <div class="alert alert-warning">
                    <div><strong>Sugerencia por versiones existentes</strong></div>
                    <div>Código sugerido: @_versionSuggestion.Codigo</div>
                    <div>Versión sugerida: @_versionSuggestion.Version</div>
                    <button class="btn btn-sm btn-outline-dark mt-2" type="button" @onclick="GenerateVersioningAsync">Aplicar sugerencia</button>
                </div>
            }

            <div class="alert alert-info">
                <div><strong>Código final:</strong> @WizardState.Draft.Codigo</div>
                <div><strong>Versión:</strong> @WizardState.Draft.Version</div>
                <button class="btn btn-sm btn-outline-primary mt-2" type="button" @onclick="GenerateVersioningAsync">Autogenerar código/versionado</button>
            </div>

            <div class="mb-3">
                <label class="form-label">Modelo clasificación</label>
                <InputSelect class="form-select" @bind-Value="WizardState.Draft.ModeloClasificacionDI" @bind-Value:after="MarkDirtyAsync">
                    <option value="">Selecciona modelo...</option>
                    @foreach (var model in _clasificacionModels)
                    {
                        <option value="@model.Key">@model.Key (@model.Provider)</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Umbral clasificación (0..1)</label>
                <InputNumber class="form-control" @bind-Value="WizardState.Draft.UmbralClasificacion" @bind-Value:after="MarkDirtyAsync" />
            </div>

            <hr />
            <h5>Classification (TDN)</h5>

            <div class="mb-3">
                <label class="form-label">TDN1</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.Tdn1" @bind-Value:after="MarkDirtyAsync" />
            </div>

            <div class="mb-3">
                <label class="form-label">TDN2</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.Tdn2" @bind-Value:after="MarkDirtyAsync" />
            </div>

            <div class="mb-3">
                <label class="form-label">Descripción GPT de tipología</label>
                <InputTextArea class="form-control" @bind-Value="WizardState.Draft.GptDescripcion" @bind-Value:after="MarkDirtyAsync" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="WizardState.Draft.EnableRules" @bind-Value:after="MarkDirtyAsync" />
                <label class="form-check-label">Habilitar reglas de clasificación para esta tipología</label>
            </div>

            <div class="mb-3">
                <label class="form-label">Example phrases (una por línea)</label>
                <InputTextArea class="form-control" Value="@string.Join("\n", WizardState.Draft.ExamplePhrases)" ValueChanged="UpdateExamplePhrasesAsync" />
            </div>

            <div class="mb-3">
                <label class="form-label">Disambiguation hints (una por línea)</label>
                <InputTextArea class="form-control" Value="@string.Join("\n", WizardState.Draft.DisambiguationHints)" ValueChanged="UpdateDisambiguationHintsAsync" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="WizardState.Draft.EnableExtraction" @bind-Value:after="MarkDirtyAsync" />
                <label class="form-check-label">Habilitar extraction</label>
            </div>

            @if (WizardState.Draft.EnableExtraction)
            {
                <div class="mb-3">
                    <label class="form-label">Modelo extracción</label>
                    <InputSelect class="form-select" @bind-Value="WizardState.Draft.ModeloExtraccionDI" @bind-Value:after="MarkDirtyAsync">
                        <option value="">Selecciona modelo...</option>
                        @foreach (var model in _extraccionModels)
                        {
                            <option value="@model.Key">@model.Key (@model.Provider)</option>
                        }
                    </InputSelect>
                </div>

                <div class="mb-3">
                    <label class="form-label">Umbral extracción (0..1)</label>
                    <InputNumber class="form-control" @bind-Value="WizardState.Draft.UmbralExtraccion" @bind-Value:after="MarkDirtyAsync" />
                </div>
            }

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="WizardState.Draft.EnablePrompting" @bind-Value:after="MarkDirtyAsync" />
                <label class="form-check-label">Habilitar prompting</label>
            </div>

            @if (WizardState.Draft.EnablePrompting)
            {
                <div class="mb-3">
                    <label class="form-label">Modelo prompting</label>
                    <InputSelect class="form-select" @bind-Value="WizardState.Draft.PromptModelKey" @bind-Value:after="MarkDirtyAsync">
                        <option value="">Selecciona modelo...</option>
                        @foreach (var model in _promptModels)
                        {
                            <option value="@model.Key">@model.Key (@model.Provider)</option>
                        }
                    </InputSelect>
                </div>

                <div class="mb-3">
                    <label class="form-label">Prompt</label>
                    <InputTextArea class="form-control" @bind-Value="WizardState.Draft.PromptGPT" @bind-Value:after="MarkDirtyAsync" />
                </div>
            }
        }
        else if (WizardState.CurrentStep == 3)
        {
            <div class="mb-2 d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Campos</h5>
                <button class="btn btn-sm btn-outline-primary" type="button" @onclick="AddFieldAsync">Agregar campo</button>
            </div>

            @for (var i = 0; i < WizardState.Draft.Fields.Count; i++)
            {
                var index = i;
                <div class="border rounded p-2 mb-2">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <label class="form-label">Nombre</label>
                            <input class="form-control" value="@WizardState.Draft.Fields[index].Name" @onchange="async e => await UpdateFieldNameAsync(index, e)" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Tipo</label>
                            <select class="form-select" value="@WizardState.Draft.Fields[index].Type" @onchange="async e => await UpdateFieldTypeAsync(index, e)">
                                <option value="string">string</option>
                                <option value="decimal">decimal</option>
                                <option value="date">date</option>
                                <option value="boolean">boolean</option>
                                <option value="array">array</option>
                                <option value="object">object</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">SourcePath (opcional)</label>
                            <input class="form-control" value="@WizardState.Draft.Fields[index].SourcePath" @onchange="async e => await UpdateFieldSourcePathAsync(index, e)" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Descripción</label>
                            <input class="form-control" value="@WizardState.Draft.Fields[index].Description" @onchange="async e => await UpdateFieldDescriptionAsync(index, e)" />
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <button class="btn btn-outline-danger" type="button" @onclick="() => RemoveFieldAsync(index)">X</button>
                        </div>
                    </div>

                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" checked="@WizardState.Draft.Fields[index].Required" @onchange="async e => await UpdateFieldRequiredAsync(index, e)" />
                        <label class="form-check-label">Obligatorio</label>
                    </div>

                    <div class="mt-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="fw-semibold">Reglas de validación</small>
                            <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => AddRuleAsync(index)">Agregar regla</button>
                        </div>

                        @for (var r = 0; r < WizardState.Draft.Fields[index].Rules.Count; r++)
                        {
                            var ruleIndex = r;
                            <div class="row g-2 mt-1" @key="@($"rule-{index}-{ruleIndex}")">
                                <div class="col-md-3">
                                    <select class="form-select" value="@WizardState.Draft.Fields[index].Rules[ruleIndex].RuleType" @onchange="async e => await UpdateRuleTypeAsync(index, ruleIndex, e)">
                                        <option value="">tipo...</option>
                                        <option value="range">range</option>
                                        <option value="regex">regex</option>
                                        <option value="enum">enum</option>
                                        <option value="date">date</option>
                                        <option value="minlength">minlength</option>
                                        <option value="maxlength">maxlength</option>
                                        <option value="required">required</option>
                                        <option value="nif">nif</option>
                                        <option value="catastral">catastral</option>
                                        <option value="address">address</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <select class="form-select" value="@WizardState.Draft.Fields[index].Rules[ruleIndex].Severity" @onchange="async e => await UpdateRuleSeverityAsync(index, ruleIndex, e)">
                                        <option value="Error">Error</option>
                                        <option value="Warning">Warning</option>
                                        <option value="Info">Info</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    @{ var _rt = WizardState.Draft.Fields[index].Rules[ruleIndex].RuleType; }
                                    @if (_rt == "range")
                                    {
                                        <div class="d-flex gap-2">
                                            <div>
                                                <label class="form-label mb-0"><small>Mín</small></label>
                                                <input type="number" class="form-control form-control-sm" placeholder="mín"
                                                    value="@WizardState.Draft.Fields[index].Rules[ruleIndex].RangeMin"
                                                    @onchange="async e => await UpdateRuleRangeMinAsync(index, ruleIndex, e)" />
                                            </div>
                                            <div>
                                                <label class="form-label mb-0"><small>Máx</small></label>
                                                <input type="number" class="form-control form-control-sm" placeholder="máx"
                                                    value="@WizardState.Draft.Fields[index].Rules[ruleIndex].RangeMax"
                                                    @onchange="async e => await UpdateRuleRangeMaxAsync(index, ruleIndex, e)" />
                                            </div>
                                        </div>
                                    }
                                    else if (_rt == "regex")
                                    {
                                        <label class="form-label mb-0"><small>Patrón regex</small></label>
                                        <input type="text" class="form-control form-control-sm" placeholder="^[A-Z]{2}\d{4}$"
                                            value="@WizardState.Draft.Fields[index].Rules[ruleIndex].RegexPattern"
                                            @onchange="async e => await UpdateRuleRegexPatternAsync(index, ruleIndex, e)" />
                                    }
                                    else if (_rt == "enum")
                                    {
                                        <label class="form-label mb-0"><small>Valores permitidos (coma separada)</small></label>
                                        <input type="text" class="form-control form-control-sm" placeholder="Activo, Inactivo, Pendiente"
                                            value="@WizardState.Draft.Fields[index].Rules[ruleIndex].EnumValues"
                                            @onchange="async e => await UpdateRuleEnumValuesAsync(index, ruleIndex, e)" />
                                        <div class="form-check mt-1">
                                            <input class="form-check-input" type="checkbox" id="enumcs-@(index)-@(ruleIndex)"
                                                checked="@WizardState.Draft.Fields[index].Rules[ruleIndex].EnumCaseSensitive"
                                                @onchange="async e => await UpdateRuleEnumCaseSensitiveAsync(index, ruleIndex, e)" />
                                            <label class="form-check-label" for="enumcs-@(index)-@(ruleIndex)"><small>Case sensitive</small></label>
                                        </div>
                                    }
                                    else if (_rt == "date")
                                    {
                                        <label class="form-label mb-0"><small>Formatos (punto y coma, vacío=defecto)</small></label>
                                        <input type="text" class="form-control form-control-sm" placeholder="dd/MM/yyyy; yyyy-MM-dd"
                                            value="@WizardState.Draft.Fields[index].Rules[ruleIndex].DateFormats"
                                            @onchange="async e => await UpdateRuleDateFormatsAsync(index, ruleIndex, e)" />
                                        <div class="d-flex gap-3 mt-1">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="dateaf-@(index)-@(ruleIndex)"
                                                    checked="@WizardState.Draft.Fields[index].Rules[ruleIndex].DateAllowFuture"
                                                    @onchange="async e => await UpdateRuleDateAllowFutureAsync(index, ruleIndex, e)" />
                                                <label class="form-check-label" for="dateaf-@(index)-@(ruleIndex)"><small>Permitir futuro</small></label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="dateap-@(index)-@(ruleIndex)"
                                                    checked="@WizardState.Draft.Fields[index].Rules[ruleIndex].DateAllowPast"
                                                    @onchange="async e => await UpdateRuleDateAllowPastAsync(index, ruleIndex, e)" />
                                                <label class="form-check-label" for="dateap-@(index)-@(ruleIndex)"><small>Permitir pasado</small></label>
                                            </div>
                                        </div>
                                    }
                                    else if (_rt == "minlength" || _rt == "maxlength")
                                    {
                                        <label class="form-label mb-0"><small>@(_rt == "minlength" ? "Longitud mínima" : "Longitud máxima")</small></label>
                                        <input type="number" min="0" class="form-control form-control-sm" placeholder="0"
                                            value="@WizardState.Draft.Fields[index].Rules[ruleIndex].LengthValue"
                                            @onchange="async e => await UpdateRuleLengthValueAsync(index, ruleIndex, e)" />
                                    }
                                    else if (_rt is "required" or "nif" or "catastral" or "address")
                                    {
                                        <small class="text-muted fst-italic">Sin parámetros</small>
                                    }
                                    else if (!string.IsNullOrEmpty(_rt))
                                    {
                                        <small class="text-muted fst-italic">Parámetros no configurables desde el wizard</small>
                                    }
                                </div>
                                <div class="col-md-1">
                                    <button class="btn btn-outline-danger" type="button" @onclick="() => RemoveRuleAsync(index, ruleIndex)">X</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <hr />

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="WizardState.Draft.EnableAssetResolver" @bind-Value:after="MarkDirtyAsync" />
                <label class="form-check-label">Habilitar asset resolver</label>
            </div>

            @if (WizardState.Draft.EnableAssetResolver)
            {
                <div class="mb-3">
                    <label class="form-label">Campos solicitados a Asset Resolver (coma separada)</label>
                    <InputText class="form-control" @bind-Value="WizardState.Draft.AssetResolverCamposSolicitados" @bind-Value:after="MarkDirtyAsync" />
                </div>
            }
        }
        else if (WizardState.CurrentStep == 4)
        {
            <div class="mb-3">
                <label class="form-label">Matrícula GDC tipología</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.TipologiaMGDCMatricula" @bind-Value:after="MarkDirtyAsync" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="WizardState.Draft.SkipGdcUpload" @bind-Value:after="MarkDirtyAsync" />
                <label class="form-check-label">Omitir subida a GDC por defecto</label>
            </div>

            <div class="mb-3">
                <label class="form-label">GDC Tipo documento</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.GdcTipoDocumento" @bind-Value:after="MarkDirtyAsync" disabled="@WizardState.Draft.SkipGdcUpload" />
            </div>

            <div class="mb-3">
                <label class="form-label">GDC Subtipo documento (opcional)</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.GdcSubtipoDocumento" @bind-Value:after="MarkDirtyAsync" disabled="@WizardState.Draft.SkipGdcUpload" />
            </div>

            <div class="mb-3">
                <label class="form-label">GDC Serie</label>
                <InputText class="form-control" @bind-Value="WizardState.Draft.GdcSerie" @bind-Value:after="MarkDirtyAsync" disabled="@WizardState.Draft.SkipGdcUpload" />
            </div>
        }
        else
        {
            <div class="mb-2"><strong>Código:</strong> @WizardState.Draft.Codigo</div>
            <div class="mb-2"><strong>Nombre:</strong> @WizardState.Draft.Nombre</div>
            <div class="mb-2"><strong>Versión:</strong> @WizardState.Draft.Version</div>
            <div class="mb-2"><strong>Modo:</strong> @WizardState.Draft.StartMode</div>
            <div class="mb-2"><strong>Modelo clasificación:</strong> @WizardState.Draft.ModeloClasificacionDI</div>
            <div class="mb-2"><strong>TDN:</strong> @WizardState.Draft.Tdn1 / @WizardState.Draft.Tdn2</div>
            <div class="mb-2"><strong>EnableRules:</strong> @(WizardState.Draft.EnableRules ? "Sí" : "No")</div>
            <div class="mb-2"><strong>Extraction:</strong> @(WizardState.Draft.EnableExtraction ? "Sí" : "No")</div>
            @if (WizardState.Draft.EnableExtraction)
            {
                <div class="mb-2"><strong>Modelo extracción:</strong> @WizardState.Draft.ModeloExtraccionDI</div>
            }
            <div class="mb-2"><strong>Prompting:</strong> @(WizardState.Draft.EnablePrompting ? "Sí" : "No")</div>
            @if (WizardState.Draft.EnablePrompting)
            {
                <div class="mb-2"><strong>Modelo prompting:</strong> @WizardState.Draft.PromptModelKey</div>
            }
            <div class="mb-2"><strong>Asset Resolver:</strong> @(WizardState.Draft.EnableAssetResolver ? "Sí" : "No")</div>
            <div class="mb-2"><strong>Campos definidos:</strong> @WizardState.Draft.Fields.Count</div>
            <div class="mb-2"><strong>Skip GDC:</strong> @(WizardState.Draft.SkipGdcUpload ? "Sí" : "No")</div>

            <details>
                <summary>Previsualizar JSON de configuración</summary>
                <pre class="mt-2">@WizardState.BuildConfigurationJson()</pre>
            </details>
        }
    </div>
</div>

@if (_stepErrors.TryGetValue(WizardState.CurrentStep, out var currentErrors) && currentErrors.Count > 0)
{
    <div class="alert alert-danger">
        <strong>Errores del paso @WizardState.CurrentStep:</strong>
        <ul class="mb-0">
            @foreach (var error in currentErrors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<div class="mb-3">
    <button class="btn btn-secondary" @onclick="PreviousAsync" disabled="@(WizardState.CurrentStep == 1)">Atrás</button>

    @if (WizardState.CurrentStep < WizardState.TotalSteps)
    {
        <button class="btn btn-primary ms-2" @onclick="NextAsync">Siguiente</button>
    }
    else
    {
        <button class="btn btn-success ms-2" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Guardando..." : "Crear Draft")</button>
        <button class="btn btn-outline-success ms-2" @onclick="PublishAsync" disabled="@_saving">@(_saving ? "Procesando..." : "Crear y publicar")</button>
    }

    <button class="btn btn-outline-secondary ms-2" @onclick="SaveDraftOnlyAsync">Guardar borrador local</button>
    <a class="btn btn-link ms-2" href="/tipologias">Cancelar</a>
</div>

@code {
    private readonly Dictionary<int, List<string>> _stepErrors = new();
    private IReadOnlyCollection<TipologiaEntity> _tipologias = Array.Empty<TipologiaEntity>();
    private IReadOnlyCollection<ModeloConfigEntity> _clasificacionModels = Array.Empty<ModeloConfigEntity>();
    private IReadOnlyCollection<ModeloConfigEntity> _extraccionModels = Array.Empty<ModeloConfigEntity>();
    private IReadOnlyCollection<ModeloConfigEntity> _promptModels = Array.Empty<ModeloConfigEntity>();
    private int? _cloneSourceId;
    private bool _saving;
    private bool _error;
    private string? _message;
    private TipologiaWizardVersionSuggestion? _versionSuggestion;
    private bool _draftLoaded;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tipologias = await AdminService.GetTipologiasAsync();
            _clasificacionModels = (await AdminService.GetModelosByTipoAsync(TipoModelo.Clasificacion)).Where(m => m.Activo).ToArray();
            _extraccionModels = (await AdminService.GetModelosByTipoAsync(TipoModelo.Extraccion)).Where(m => m.Activo).ToArray();
            _promptModels = (await AdminService.GetModelosByTipoAsync(TipoModelo.Prompt)).Where(m => m.Activo).ToArray();
        }
        catch (Exception ex)
        {
            _tipologias = Array.Empty<TipologiaEntity>();
            _clasificacionModels = Array.Empty<ModeloConfigEntity>();
            _extraccionModels = Array.Empty<ModeloConfigEntity>();
            _promptModels = Array.Empty<ModeloConfigEntity>();
            _error = true;
            _message = $"No se pudo cargar la configuración desde la API COMPLETAR_GDC_HTTP_BASIC_USERNAME. Detalle: {ex.Message}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _draftLoaded)
        {
            return;
        }

        _draftLoaded = true;
        await WizardState.LoadDraftAsync(JS);

        _cloneSourceId = WizardState.Draft.SourceTipologiaId;
        _versionSuggestion = WizardState.SuggestVersionedCodigoAndVersion(_tipologias);

        if (WizardState.Draft.Fields.Count == 0)
        {
            WizardState.AddField();
            await WizardState.SaveDraftAsync(JS);
        }

        StateHasChanged();
    }

