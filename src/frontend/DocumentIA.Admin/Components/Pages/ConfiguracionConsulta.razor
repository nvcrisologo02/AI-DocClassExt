@page "/configuracion-consulta"
@inject SystemConfigService SystemConfigService
@rendermode InteractiveServer

<PageTitle>Consulta de Configuración del Sistema</PageTitle>

<div class="container-fluid mt-4">
    <h1>Consulta de Configuración del Sistema</h1>
    <p class="text-muted">Vista consolidada del estado de configuración de tipologías, modelos, plugins e información del sistema.</p>

    @if (_isLoading)
    {
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    }
    else if (_error && !string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Error</h4>
            <p>@_errorMessage</p>
        </div>
    }
    else if (_config != null)
    {
        <div class="row">
            <!-- TIPOLOGÍAS -->
            <div class="col-12 col-lg-6 mb-3">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">📋 Tipologías</h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center mb-3">
                            <div class="col-3">
                                <div class="h4 text-primary">@_config.TipologiasTotal</div>
                                <small class="text-muted">Total</small>
                            </div>
                            <div class="col-3">
                                <div class="h4 text-success">@_config.TipologiasPublished</div>
                                <small class="text-muted">Publicadas</small>
                            </div>
                            <div class="col-3">
                                <div class="h4 text-warning">@_config.TipologiasDraft</div>
                                <small class="text-muted">Draft</small>
                            </div>
                            <div class="col-3">
                                <div class="h4 text-danger">@_config.TipologiasRetired</div>
                                <small class="text-muted">Retiradas</small>
                            </div>
                        </div>
                        <dl class="row small mb-0">
                            <dt class="col-8">Tipologías Activas:</dt>
                            <dd class="col-4 text-end"><span class="badge bg-success">@_config.TipologiasActivas</span></dd>
                        </dl>
                    </div>
                </div>
            </div>

            <!-- MODELOS -->
            <div class="col-12 col-lg-6 mb-3">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">🧠 Modelos</h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center mb-3">
                            <div class="col-3">
                                <div class="h4 text-success">@_config.ModelosTotal</div>
                                <small class="text-muted">Total</small>
                            </div>
                            <div class="col-3">
                                <div class="h4">@_config.ModelosClasificacion</div>
                                <small class="text-muted">Clasif.</small>
                            </div>
                            <div class="col-3">
                                <div class="h4">@_config.ModelosExtraccion</div>
                                <small class="text-muted">Extracc.</small>
                            </div>
                            <div class="col-3">
                                <div class="h4">@_config.ModelosPrompt</div>
                                <small class="text-muted">Prompts</small>
                            </div>
                        </div>
                        <dl class="row small mb-0">
                            <dt class="col-8">Modelos Activos:</dt>
                            <dd class="col-4 text-end"><span class="badge bg-success">@_config.ModelosActivos</span></dd>
                            <dt class="col-8">Providers Únicos:</dt>
                            <dd class="col-4 text-end"><span class="badge bg-info">@_config.ProvidersUsados.Count</span></dd>
                        </dl>
                    </div>
                </div>
            </div>

            <!-- PLUGINS -->
            <div class="col-12 col-lg-6 mb-3">
                <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">⚙️ Plugins</h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center mb-3">
                            <div class="col-4">
                                <div class="h4 text-warning">@_config.PluginsTotal</div>
                                <small class="text-muted">Total</small>
                            </div>
                            <div class="col-4">
                                <div class="h4 text-success">@_config.PluginsPublished</div>
                                <small class="text-muted">Publicados</small>
                            </div>
                            <div class="col-4">
                                <div class="h4 text-info">@_config.PluginsDraft</div>
                                <small class="text-muted">Draft</small>
                            </div>
                        </div>
                        <dl class="row small mb-0">
                            <dt class="col-8">Tipologías con Plugins:</dt>
                            <dd class="col-4 text-end"><span class="badge bg-warning">@_config.TipologiasConPlugins</span></dd>
                        </dl>
                    </div>
                </div>
            </div>

            <!-- INFORMACIÓN DEL SISTEMA -->
            <div class="col-12 col-lg-6 mb-3">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">🖥️ Información del Sistema</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-borderless mb-0">
                                <tbody>
                                    <tr>
                                        <td class="text-muted"><small><strong>Entorno:</strong></small></td>
                                        <td class="text-end"><span class="badge bg-primary">@_config.Environment</span></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted"><small>.NET Runtime:</small></td>
                                        <td class="text-end"><small>@_config.DotNetVersion</small></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted"><small>Sistema Operativo:</small></td>
                                        <td class="text-end"><small>@_config.OS</small></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted"><small>Zona Horaria:</small></td>
                                        <td class="text-end"><small>@_config.TimeZone</small></td>
                                    </tr>
                                    @if (!string.IsNullOrWhiteSpace(_config.FunctionsBaseUrl))
                                    {
                                        <tr>
                                            <td class="text-muted"><small>API Functions:</small></td>
                                            <td class="text-end"><small class="text-break"><code style="font-size: 0.75rem;">@_config.FunctionsBaseUrl</code></small></td>
                                        </tr>
                                    }
                                    <tr>
                                        <td class="text-muted"><small>Actualizado:</small></td>
                                        <td class="text-end"><small>@_config.Timestamp.ToString("HH:mm:ss")</small></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        @if (_config.ProvidersUsados.Any())
                        {
                            <div class="mt-3 pt-3 border-top">
                                <small class="text-muted d-block mb-2"><strong>Providers Configurados:</strong></small>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var provider in _config.ProvidersUsados)
                                    {
                                        <span class="badge bg-secondary">@provider</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button class="btn btn-outline-secondary" @onclick="ReloadAsync">
                <span class="me-2">🔄</span> Actualizar
            </button>
            <small class="text-muted ms-3">Última actualización: @_config.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</small>
        </div>
    }
</div>

@code {
    private SystemConfiguration? _config;
    private bool _isLoading = true;
    private bool _error = false;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        try
        {
            _isLoading = true;
            _error = false;
            _errorMessage = null;

            _config = await SystemConfigService.GetConfigurationResumenAsync();

            _isLoading = false;
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = $"Error al cargar configuración: {ex.Message}";
            _isLoading = false;
        }
    }
}
