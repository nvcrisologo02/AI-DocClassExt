@page "/modelos"
@inject TipologiaAdminService AdminService
@inject NavigationManager Navigation

<PageTitle>Modelos</PageTitle>

<h1>Modelos</h1>

<p>
    <button class="btn btn-primary" @onclick="CreateModelo">Nuevo modelo</button>
</p>

<h3>Clasificación</h3>
@RenderTable(_clasificacion)

<h3>Extracción</h3>
@RenderTable(_extraccion)

<h3>Prompt</h3>
@RenderTable(_prompt)

@code {
    private IReadOnlyCollection<ModeloConfigEntity> _clasificacion = Array.Empty<ModeloConfigEntity>();
    private IReadOnlyCollection<ModeloConfigEntity> _extraccion = Array.Empty<ModeloConfigEntity>();
    private IReadOnlyCollection<ModeloConfigEntity> _prompt = Array.Empty<ModeloConfigEntity>();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _clasificacion = await AdminService.GetModelosByTipoAsync(TipoModelo.Clasificacion);
        _extraccion = await AdminService.GetModelosByTipoAsync(TipoModelo.Extraccion);
        _prompt = await AdminService.GetModelosByTipoAsync(TipoModelo.Prompt);
    }

    private void CreateModelo()
    {
        Navigation.NavigateTo("/modelos/edit");
    }

    private void EditModelo(int id)
    {
        Navigation.NavigateTo($"/modelos/edit/{id}");
    }

    private async Task DeleteModeloAsync(int id)
    {
        await AdminService.DeleteModeloAsync(id);
        await ReloadAsync();
        StateHasChanged();
    }

    private RenderFragment RenderTable(IReadOnlyCollection<ModeloConfigEntity> rows) => builder =>
    {
        var seq = 0;
        builder.OpenElement(seq++, "table");
        builder.AddAttribute(seq++, "class", "table table-striped");

        builder.OpenElement(seq++, "thead");
        builder.OpenElement(seq++, "tr");
        builder.OpenElement(seq++, "th"); builder.AddContent(seq++, "Key"); builder.CloseElement();
        builder.OpenElement(seq++, "th"); builder.AddContent(seq++, "Provider"); builder.CloseElement();
        builder.OpenElement(seq++, "th"); builder.AddContent(seq++, "Activo"); builder.CloseElement();
        builder.OpenElement(seq++, "th"); builder.AddContent(seq++, "Acciones"); builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(seq++, "tbody");
        foreach (var row in rows)
        {
            builder.OpenElement(seq++, "tr");
            builder.OpenElement(seq++, "td"); builder.AddContent(seq++, row.Key); builder.CloseElement();
            builder.OpenElement(seq++, "td"); builder.AddContent(seq++, row.Provider); builder.CloseElement();
            builder.OpenElement(seq++, "td"); builder.AddContent(seq++, row.Activo ? "Si" : "No"); builder.CloseElement();
            builder.OpenElement(seq++, "td");
            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "class", "btn btn-sm btn-outline-secondary");
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => EditModelo(row.Id)));
            builder.AddContent(seq++, "Editar");
            builder.CloseElement();
            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "class", "btn btn-sm btn-outline-danger ms-2");
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => DeleteModeloAsync(row.Id)));
            builder.AddContent(seq++, "Borrar");
            builder.CloseElement();
            builder.CloseElement();
            builder.CloseElement();
        }
        builder.CloseElement();
        builder.CloseElement();
    };
}
