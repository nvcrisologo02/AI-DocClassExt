@page "/tipologias"
@inject TipologiaAdminService AdminService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Tipologías</PageTitle>

<h1>Tipologías</h1>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <label class="form-label">Buscar</label>
        <InputText class="form-control" @bind-Value="_searchTerm" placeholder="Código, Nombre..." />
    </div>
</div>

<p>
    <button class="btn btn-primary" @onclick="CreateTipologia">Nueva tipología</button>
</p>

@if (_loading)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th style="cursor: pointer;" @onclick="@(() => SortBy("Codigo"))">Codigo @SortIndicator("Codigo")</th>
                <th style="cursor: pointer;" @onclick="@(() => SortBy("Nombre"))">Nombre @SortIndicator("Nombre")</th>
                <th style="cursor: pointer;" @onclick="@(() => SortBy("Version"))">Version @SortIndicator("Version")</th>
                <th style="cursor: pointer;" @onclick="@(() => SortBy("Estado"))">Estado @SortIndicator("Estado")</th>
                <th style="cursor: pointer;" @onclick="@(() => SortBy("FechaActualizacion"))">Actualizado @SortIndicator("FechaActualizacion")</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tipologia in GetFilteredAndSortedTipologias())
            {
                <tr>
                    <td>@tipologia.Codigo</td>
                    <td>@tipologia.Nombre</td>
                    <td>@tipologia.Version</td>
                    <td>@tipologia.Estado</td>
                    <td>@(tipologia.FechaActualizacion?.ToString("u") ?? "-")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="/tipologias/@tipologia.Id">Detalle</a>
                            @if (tipologia.Estado is EstadoTipologia.Draft or EstadoTipologia.Retired)
                        {
                            <a class="btn btn-sm btn-outline-secondary ms-2" href="/tipologias/edit/@tipologia.Id">Editar</a>
                        }
                        else
                        {
                                <button class="btn btn-sm btn-outline-secondary ms-2" disabled title="Solo se pueden editar tipologías en estado Draft o Retired.">Editar</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private string _searchTerm = string.Empty;
    private string _sortColumn = "Codigo";
    private bool _sortAscending = true;
    private IReadOnlyCollection<TipologiaEntity> _tipologias = Array.Empty<TipologiaEntity>();

    protected override async Task OnInitializedAsync()
    {
        _tipologias = await AdminService.GetTipologiasAsync();
        _loading = false;
    }

    private void CreateTipologia()
    {
        Navigation.NavigateTo("/tipologias/edit");
    }

    private void SortBy(string column)
    {
        if (_sortColumn == column)
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private string SortIndicator(string column)
    {
        if (_sortColumn != column) return "";
        return _sortAscending ? "▲" : "▼";
    }

    private IEnumerable<TipologiaEntity> GetFilteredAndSortedTipologias()
    {
        var query = _tipologias.AsEnumerable();

        // Filtro de búsqueda
        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var searchLower = _searchTerm.ToLower();
            query = query.Where(t =>
                (t.Codigo?.ToLower().Contains(searchLower) ?? false) ||
                (t.Nombre?.ToLower().Contains(searchLower) ?? false)
            );
        }

        // Ordenamiento
        query = _sortColumn switch
        {
            "Nombre" => _sortAscending ? query.OrderBy(t => t.Nombre) : query.OrderByDescending(t => t.Nombre),
            "Version" => _sortAscending ? query.OrderBy(t => t.Version) : query.OrderByDescending(t => t.Version),
            "Estado" => _sortAscending ? query.OrderBy(t => t.Estado) : query.OrderByDescending(t => t.Estado),
            "FechaActualizacion" => _sortAscending ? query.OrderBy(t => t.FechaActualizacion) : query.OrderByDescending(t => t.FechaActualizacion),
            _ => _sortAscending ? query.OrderBy(t => t.Codigo) : query.OrderByDescending(t => t.Codigo)
        };

        return query;
    }
}
