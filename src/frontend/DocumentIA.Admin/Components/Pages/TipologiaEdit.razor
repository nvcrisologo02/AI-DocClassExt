@page "/tipologias/edit"
@page "/tipologias/edit/{Id:int}"
@using System.Text.Json
@using DocumentIA.Core.Configuration
@inject TipologiaAdminService AdminService
@inject NavigationManager Navigation

<PageTitle>Editar Tipología</PageTitle>

<h1>@(Id.HasValue ? "Editar Tipología" : "Nueva Tipología")</h1>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_error ? "alert-danger" : "alert-success")">@_message</div>
}

@if (Id.HasValue && !_isEditable)
{
    <div class="alert alert-warning">Solo se pueden editar tipologías en estado Draft. Esta tipología está en estado <strong>@_model.Estado</strong>.</div>
}

@if (!Id.HasValue)
{
    <div class="mb-3">
        <strong>Plantillas predefinidas:</strong>
        <div class="button-group gap-2">
            <button class="btn btn-outline-secondary btn-sm" @onclick='() => ApplyTemplate("notasimple")' disabled="@(!_isEditable)">
                Plantilla: Nota Simple
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick='() => ApplyTemplate("tasacion")' disabled="@(!_isEditable)">
                Plantilla: Tasación
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick='() => ApplyTemplate("generica")' disabled="@(!_isEditable)">
                Plantilla: Genérica
            </button>
        </div>
    </div>
}

<div class="mb-3">
    <label class="form-label">Codigo</label>
    <InputText class="form-control" @bind-Value="_model.Codigo" disabled="@(!_isEditable || Id.HasValue)" />
    @if (Id.HasValue)
    {
        <small class="text-muted">El código queda bloqueado tras el primer guardado.</small>
    }
</div>

<div class="mb-3">
    <label class="form-label">Nombre</label>
    <InputText class="form-control" @bind-Value="_model.Nombre" disabled="@(!_isEditable)" />
</div>

<div class="mb-3">
    <label class="form-label">Version</label>
    <InputText class="form-control" @bind-Value="_model.Version" disabled="@(!_isEditable)" />
</div>

<div class="mb-3">
    <label class="form-label">Configuración JSON</label>
    <JsonEditorComponent 
        @ref="_jsonEditor"
        JsonContent="@_model.ConfiguracionJson"
        Mode="form"
        ReadOnly="@(!_isEditable)"
        Height="450px"
        SupportedModes="@(new List<string> { "tree", "form", "code" })" />
</div>

<div class="mb-3">
    <button class="btn btn-outline-primary" type="button" @onclick="ValidateJsonAsync" disabled="@(!_isEditable)">Validar JSON</button>
    <button class="btn btn-primary ms-2" type="button" @onclick="SaveAsync" disabled="@(!_isEditable)">Guardar</button>
    <a class="btn btn-secondary ms-2" href="/tipologias">Volver</a>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private TipologiaEntity _model = new();
    private bool _error;
    private string? _message;
    private bool _isEditable = true;
    private JsonEditorComponent? _jsonEditor;

    protected override async Task OnParametersSetAsync()
    {
        _isEditable = true;
        _message = null;
        _error = false;

        if (Id.HasValue)
        {
            var existing = await AdminService.GetTipologiaAsync(Id.Value);
            if (existing is not null)
            {
                _model = existing;
                _isEditable = existing.Estado == EstadoTipologia.Draft;
            }
        }
    }

    private async Task ValidateJsonAsync()
    {
        if (_jsonEditor == null) return;

        var isValid = await _jsonEditor.ValidateAsync();
        if (isValid)
        {
            _error = false;
            _message = "Configuración válida.";
        }
        else
        {
            _error = true;
            _message = "El JSON contiene errores. Revisalo en el editor.";
        }
    }

    private void ApplyTemplate(string templateCode)
    {
        switch (templateCode)
        {
            case "notasimple":
                if (string.IsNullOrWhiteSpace(_model.Nombre))
                {
                    _model.Nombre = "Nota simple";
                }
                InitializeTemplateConfig("notasimple", "di-clasificacion-default", "cu-notasimple-v1", "NOTS", "AI09", false);
                break;
            case "tasacion":
                if (string.IsNullOrWhiteSpace(_model.Nombre))
                {
                    _model.Nombre = "Tasacion";
                }
                InitializeTemplateConfig("tasacion", "di-clasificacion-default", "cu-tasacion-v1", "TASA", "AI05", false);
                break;
            case "generica":
                if (string.IsNullOrWhiteSpace(_model.Nombre))
                {
                    _model.Nombre = "Documento generico";
                }
                InitializeTemplateConfig("generica", "di-clasificacion-default", null, null, null, true);
                break;
        }
        StateHasChanged();
    }

    private void InitializeTemplateConfig(string template, string modeloClasificacion, string? modeloExtraccion, string? gdcTipo, string? gdcSerie, bool skipGdc)
    {
        var config = TryParseConfig(_model.ConfiguracionJson);
        
        if (string.IsNullOrWhiteSpace(config.ModeloClasificacionDI))
        {
            config.ModeloClasificacionDI = modeloClasificacion;
        }
        
        if (!string.IsNullOrWhiteSpace(modeloExtraccion))
        {
            if (string.IsNullOrWhiteSpace(config.ModeloExtraccionDI))
            {
                config.ModeloExtraccionDI = modeloExtraccion;
                config.EnableExtraction = true;
            }
        }
        else
        {
            config.EnableExtraction = false;
        }
        
        if (!string.IsNullOrWhiteSpace(gdcTipo) && string.IsNullOrWhiteSpace(config.GdcTipoDocumento))
        {
            config.GdcTipoDocumento = gdcTipo;
        }
        
        if (!string.IsNullOrWhiteSpace(gdcSerie) && string.IsNullOrWhiteSpace(config.GdcSerie))
        {
            config.GdcSerie = gdcSerie;
        }
        
        config.SkipGDCUpload = skipGdc;
        
        _model.ConfiguracionJson = JsonSerializer.Serialize(config, new JsonSerializerOptions { WriteIndented = true });
    }

    private static TemplateConfig TryParseConfig(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return new TemplateConfig();
        }

        try
        {
            var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            return new TemplateConfig
            {
                ModeloClasificacionDI = root.TryGetProperty("ModeloClasificacionDI", out var m1) ? m1.GetString() ?? "" : "",
                ModeloExtraccionDI = root.TryGetProperty("ModeloExtraccionDI", out var m2) ? m2.GetString() ?? "" : "",
                EnableExtraction = root.TryGetProperty("EnableExtraction", out var e) && e.GetBoolean(),
                GdcTipoDocumento = root.TryGetProperty("GdcTipoDocumento", out var g1) ? g1.GetString() ?? "" : "",
                GdcSerie = root.TryGetProperty("GdcSerie", out var g2) ? g2.GetString() ?? "" : "",
                SkipGDCUpload = root.TryGetProperty("SkipGDCUpload", out var s) && s.GetBoolean()
            };
        }
        catch
        {
            return new TemplateConfig();
        }
    }

    private sealed class TemplateConfig
    {
        public string ModeloClasificacionDI { get; set; } = string.Empty;
        public string ModeloExtraccionDI { get; set; } = string.Empty;
        public bool EnableExtraction { get; set; }
        public string GdcTipoDocumento { get; set; } = string.Empty;
        public string GdcSerie { get; set; } = string.Empty;
        public bool SkipGDCUpload { get; set; }
    }

    private async Task SaveAsync()
    {
        if (!_isEditable)
        {
            _error = true;
            _message = "Solo se pueden editar tipologías en estado Draft.";
            return;
        }

        // Obtener JSON del editor
        if (_jsonEditor != null)
        {
            var jsonFromEditor = await _jsonEditor.GetJsonAsync();
            if (!string.IsNullOrWhiteSpace(jsonFromEditor))
            {
                _model.ConfiguracionJson = NormalizeTipologiaConfigJsonForCompatibility(jsonFromEditor);
            }
        }

        var errors = await AdminService.ValidateTipologiaAsync(_model, Id);
        if (errors.Count > 0)
        {
            _error = true;
            _message = string.Join("\n", errors);
            return;
        }

        try
        {
            await AdminService.SaveTipologiaAsync(_model);
            Navigation.NavigateTo("/tipologias");
        }
        catch (Exception ex)
        {
            _error = true;
            _message = ex.Message;
        }
    }

    private static string NormalizeTipologiaConfigJsonForCompatibility(string json)
    {
        var config = JsonSerializer.Deserialize<TipologiaValidationConfig>(json, new JsonSerializerOptions
        {
            PropertyNameCaseInsensitive = true,
            WriteIndented = true
        });

        if (config is null)
        {
            return json;
        }

        config.Gdc = new GdcConfig
        {
            SkipUpload = config.ResolvedSkipGDCUpload,
            Matricula = config.ResolvedMatricula,
            TipoDocumento = config.ResolvedGdcTipo,
            SubtipoDocumento = config.ResolvedGdcSubtipo,
            Serie = config.ResolvedGdcSerie
        };

        config.Classification = new ClassificationTdnConfig
        {
            Tdn1 = config.ResolvedTdn1,
            Tdn2 = config.ResolvedTdn2,
            GptDescripcion = config.ResolvedGptDescripcion,
            EnableRules = config.ResolvedEnableRules
        };

        config.SkipGDCUpload = config.ResolvedSkipGDCUpload;
        config.TipologiaMGDCMatricula = config.ResolvedMatricula;
        config.GdcTipoDocumento = config.ResolvedGdcTipo;
        config.GdcSubtipoDocumento = config.ResolvedGdcSubtipo;
        config.GdcSerie = config.ResolvedGdcSerie;
        config.Tdn1 = config.ResolvedTdn1;
        config.Tdn2 = config.ResolvedTdn2;
        config.GptDescripcion = config.ResolvedGptDescripcion;

        return JsonSerializer.Serialize(config, new JsonSerializerOptions
        {
            WriteIndented = true
        });
    }
}
