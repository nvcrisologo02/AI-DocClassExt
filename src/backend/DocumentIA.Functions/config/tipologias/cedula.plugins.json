{
  "tipologiaId": "cedula",
  "plugins": [
    {
      "pluginKey": "gdc-integration",
      "pluginType": "rest",
      "returnsIdActivo": true,
      "enabled": true,
      "priority": 1,
      "configuration": {
        "baseUrl": "https://gdc.sareb.local/api",
        "authType": "ApiKey",
        "authToken": "YOUR_GDC_API_KEY",
        "timeoutSeconds": 45,
        "headers": {
          "X-System": "DocumentIA"
        }
      },
      "retryPolicy": {
        "maxRetries": 3,
        "initialDelayMs": 2000,
        "exponentialBackoff": true,
        "retryOnStatusCodes": [408, 500, 502, 503]
      }
    }
  ]
}
