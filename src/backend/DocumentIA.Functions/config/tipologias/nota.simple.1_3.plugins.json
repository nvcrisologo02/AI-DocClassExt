{
  "tipologiaId": "nota.simple.1_3",
  "plugins": [    
    {
      "pluginKey": "httpbin-test",
      "pluginType": "rest",
      "enabled": true,
      "priority": 3,
      "configuration": {
        "baseUrl": "https://httpbin.org",
        "authType": "None",
        "endpoint": "/post",
        "timeoutSeconds": 10
      },
      "retryPolicy": {
        "maxRetries": 2,
        "initialDelayMs": 500,
        "exponentialBackoff": true,
        "retryOnStatusCodes": [408, 429, 500, 502, 503, 504]
      }
    },
    {
      "pluginKey": "mock-enrichment",
      "pluginType": "rest",
      "enabled": true,
      "priority": 1,
      "configuration": {
        "baseUrl": "http://localhost:8080",
        
        "authType": "None",
        "timeoutSeconds": 10,
        "endpoint": "/"   
      },
      "retryPolicy": {
        "maxRetries": 2,
        "initialDelayMs": 500,
        "exponentialBackoff": true,
        "retryOnStatusCodes": [408, 429, 500, 502, 503, 504]
      }
    }
  ]
}
