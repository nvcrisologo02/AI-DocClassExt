      ]
    },
    {
      "name": "FechaDocumento",
      "type": "date",
      "required": true,
      "rules": [
        {
          "ruleType": "date",
          "severity": "Error",
          "parameters": {
            "formats": [ "dd/MM/yyyy", "yyyy-MM-dd" ],
            "allowFuture": false,
            "allowPast": true
          }
        }
      ]
    },
    {
      "name": "NIF",
      "type": "string",
      "required": false,
      "rules": [
        {
          "ruleType": "nif",
          "severity": "Warning",
          "parameters": {}
        }
      ]
    },
    {
      "name": "Direccion",
      "type": "string",
      "required": false,
      "rules": [
        {
          "RuleType": "address",
          "Parameters": {
            "minLength": 6,
            "maxLength": 160,
            "requireStreetNumber": true,
            "requireMunicipality": true,
            "requireProvince": false
          },
          "Severity": "Warning"
        }
      ]
    }
  ]
