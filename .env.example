# ============================================================================
# DocumentIA - Plantilla .env (referencia local de secretos / settings)
# ============================================================================
# Estos valores reflejan el contrato de secretos en Key Vault srbkvprodocai.
# Para PRODUCCION los secretos NO se cargan desde .env: la Function App usa
# referencias @Microsoft.KeyVault(...) sobre srbkvprodocai. Esta plantilla es
# util para entornos locales (Docker SQL + Azurite + endpoints reales de IA).
# ----------------------------------------------------------------------------

# --- Azure Subscription -----------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=SRBRGDOCSAIPROD

# --- Storage (Durable hub + documentos) -------------------------------------
# KV: AzureWebJobsStorage (Durable hub: srbstgproapppdocai)
AzureWebJobsStorage=UseDevelopmentStorage=true
# KV: AzureStorageConnectionString (documentos: srbstgprodocai)
AzureStorageConnectionString=UseDevelopmentStorage=true

# --- Azure SQL --------------------------------------------------------------
# KV: SqlConnectionString  (prod: srbsqlprodocai / DocumentIA, MI auth)
SqlConnectionString=Server=localhost,1433;Database=DocumentIA;User Id=sa;Password=COMPLETAR_SQL_PASSWORD;TrustServerCertificate=True;

# --- AssetResolver ----------------------------------------------------------
AssetResolver__BaseUrl=https://srbwebpluginassetresolver.azurewebsites.net/
# KV: AssetResolverApiKey  (compartida Function App <-> AssetResolver Web App)
AssetResolver__ApiKey=
# KV: user-ods-dwh  (consumido por AssetResolver via ConnectionStrings__AssetResolverDb)
ConnectionStrings__AssetResolverDb=

# --- Clasificacion: Azure Document Intelligence -----------------------------
Classification__DefaultProvider=azure-document-intelligence
Classification__AzureDocumentIntelligence__Endpoint=https://srbdiprodocai.cognitiveservices.azure.com/
# KV: Classification--AzureDocumentIntelligence--ApiKey
Classification__AzureDocumentIntelligence__ApiKey=

# --- Clasificacion: GPT fallback --------------------------------------------
Classification__GptFallback__DeploymentName=gpt-4o-mini
# KV: Classification--GptFallback--ApiKey
Classification__GptFallback__ApiKey=

# --- Extraccion: Azure Content Understanding --------------------------------
Extraction__DefaultProvider=azure-content-understanding
Extraction__AzureContentUnderstanding__Endpoint=https://upe48-mm2avmdm.cognitiveservices.azure.com/
# KV: Extraction--AzureContentUnderstanding--ApiKey
Extraction__AzureContentUnderstanding__ApiKey=

# --- Extraccion: GPT fallback -----------------------------------------------
Extraction__GptFallback__DeploymentName=gpt-4o-mini
# KV: Extraction--GptFallback--ApiKey
Extraction__GptFallback__ApiKey=

# --- GDC (gestor documental SAREB on-prem) ----------------------------------
# KV: GDC--Username, GDC--Password, GDC--HttpBasicUsername, GDC--HttpBasicPassword
GDC__Username=
GDC__Password=
GDC__HttpBasicUsername=
GDC__HttpBasicPassword=

# --- Observabilidad ---------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Runtime ----------------------------------------------------------------
FUNCTIONS_WORKER_RUNTIME=dotnet-isolated
RunDatabaseMigrationsOnStartup=true
ENVIRONMENT=Development

